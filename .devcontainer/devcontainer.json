{
	"name": "C++",
	"build": {
		"dockerfile": "Dockerfile"
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-vscode.cpptools",
				"ms-vscode.cmake-tools"
			],
			"settings": {
				"C_Cpp.default.compileCommands": "${workspaceFolder}/build/compile_commands.json",
				"cmake.configureOnOpen": true
			}
		}
	}
}
